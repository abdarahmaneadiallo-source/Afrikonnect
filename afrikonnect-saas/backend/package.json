{
  "name": "afrikonnect-backend",
  "version": "1.0.0",
  "description": "API backend Afrikonnect SaaS",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "start:railway": "npx prisma generate --schema prisma/schema.production.prisma && npx prisma db push --schema prisma/schema.production.prisma --accept-data-loss && node src/index.js",
    "seed:railway": "node prisma/seed.js",
    "dev": "nodemon src/index.js",
    "db:migrate": "npx prisma migrate dev",
    "db:generate": "npx prisma generate",
    "db:studio": "npx prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^5.0.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^4.18.0",
    "jsonwebtoken": "^9.0.0",
    "stripe": "^14.0.0",
    "nodemailer": "^6.9.0",
    "multer": "^2.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.0",
    "prisma": "^5.0.0"
  }
}
