// ===== AFRIKONNECT — SCHEMA BASE DE DONNÉES =====
// Fichier: prisma/schema.prisma
// Version SQLite (dev local) — les enums et tableaux Postgres sont
// représentés par des String (JSON pour les listes).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===== UTILISATEURS =====
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  firstName     String
  lastName      String
  phone         String?
  role          String    @default("COMMERCANT") // COMMERCANT | FOURNISSEUR | ADMIN
  plan          String    @default("FREE")       // FREE | PRO | FOURNISSEUR
  stripeCustomerId String? @unique
  stripeSubId   String?   @unique
  isVerified    Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  boutique      Boutique?
  fournisseur   Fournisseur?
  commandes     Commande[]
  messages      Message[]
  tontines      TontineMembre[]
  notifications Notification[]
}

// ===== BOUTIQUE (profil commerçant) =====
model Boutique {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id])
  nom         String
  adresse     String
  ville       String
  codePostal  String
  pays        String   @default("France")
  description String?
  categories  String   @default("[]") // JSON ["epicerie", "cosmetiques", "textile"]
  paysSource  String   @default("[]") // JSON ["CI", "SN", "CM", "NG"]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  commandes   Commande[]
}

// ===== FOURNISSEUR =====
model Fournisseur {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id])
  nomEntreprise String
  pays         String   // "CI", "SN", "NG", etc.
  ville        String
  description  String?
  certifications String @default("[]") // JSON ["ISO22000", "BIO", "HACCP"]
  noteGlobale  Float    @default(0)
  delaiMoyen   Int      @default(21) // jours
  isVerified   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  produits     Produit[]
  avis         Avis[]
}

// ===== PRODUITS =====
model Produit {
  id              String      @id @default(cuid())
  fournisseurId   String
  fournisseur     Fournisseur @relation(fields: [fournisseurId], references: [id])
  nom             String
  description     String?
  categorie       String      // "epicerie_seche", "poisson", "cosmetiques", "textile"
  prix            Float
  prixUnite       String      // "kg", "L", "unité", "lot"
  stockDisponible Int         @default(0)
  codeDouanier    String?     // Code NC européen
  tvaTaux         Float       @default(5.5)
  certifications  String      @default("[]") // JSON
  etiquettageFR   Boolean     @default(false)
  photos          String      @default("[]") // JSON URLs
  isActif         Boolean     @default(true)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  lignesCommande  LigneCommande[]
}

// ===== COMMANDES =====
model Commande {
  id            String          @id @default(cuid())
  boutiqueId    String
  boutique      Boutique        @relation(fields: [boutiqueId], references: [id])
  userId        String
  user          User            @relation(fields: [userId], references: [id])
  statut        String          @default("EN_ATTENTE") // EN_ATTENTE | CONFIRME | CHARGE | EN_TRANSIT | DOUANE | BLOQUE | LIVRE | ANNULE
  modeTransport String          @default("MARITIME")   // MARITIME | AERIEN | ROUTIER
  coutTotal     Float
  coutFret      Float           @default(0)
  poids         Float           @default(0)
  paysOrigine   String
  dateExpedition DateTime?
  dateArrivee   DateTime?
  notes         String?
  groupeId      String?
  groupe        CommandeGroupe? @relation(fields: [groupeId], references: [id])
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  lignes        LigneCommande[]
  suivis        SuiviCommande[]
  alertes       AlerteDouane[]
  messages      Message[]
}

model LigneCommande {
  id          String   @id @default(cuid())
  commandeId  String
  commande    Commande @relation(fields: [commandeId], references: [id])
  produitId   String
  produit     Produit  @relation(fields: [produitId], references: [id])
  quantite    Int
  prixUnitaire Float
  sousTotal   Float
}

// ===== SUIVI COMMANDE =====
model SuiviCommande {
  id          String   @id @default(cuid())
  commandeId  String
  commande    Commande @relation(fields: [commandeId], references: [id])
  statut      String
  description String
  lieu        String?
  createdAt   DateTime @default(now())
}

// ===== ALERTE DOUANE =====
model AlerteDouane {
  id          String   @id @default(cuid())
  commandeId  String
  commande    Commande @relation(fields: [commandeId], references: [id])
  type        String   // "CERTIFICAT_MANQUANT", "ETIQUETAGE", "LOT_BLOQUE"
  description String
  isResolu    Boolean  @default(false)
  createdAt   DateTime @default(now())
}

// ===== COMMANDES GROUPÉES =====
model CommandeGroupe {
  id          String   @id @default(cuid())
  titre       String
  origine     String   // "Abidjan", "Dakar"
  destination String   // "Lyon", "Paris"
  dateDepart  DateTime
  maxBoutiques Int     @default(5)
  statut      String   @default("OUVERT") // "OUVERT", "COMPLET", "PARTI"
  economie    Float    @default(0)
  createdAt   DateTime @default(now())

  commandes   Commande[]
}

// ===== CONFORMITÉ =====
model Conformite {
  id          String   @id @default(cuid())
  produitNom  String
  codeDouanier String?
  etiquettageFR Boolean @default(false)
  datePeremption Boolean @default(false)
  certificatSanitaire Boolean @default(false)
  tracabilite Boolean  @default(false)
  score       Int      @default(0) // 0-100
  recommandations String @default("[]") // JSON
  createdAt   DateTime @default(now())
}

// ===== MESSAGES =====
model Message {
  id          String   @id @default(cuid())
  expediteurId String
  expediteur  User     @relation(fields: [expediteurId], references: [id])
  commandeId  String?
  commande    Commande? @relation(fields: [commandeId], references: [id])
  contenu     String
  lu          Boolean  @default(false)
  createdAt   DateTime @default(now())
}

// ===== TONTINES =====
model Tontine {
  id          String   @id @default(cuid())
  nom         String
  montantPart Float
  frequence   String   @default("MENSUEL")
  statut      String   @default("ACTIF")
  createdAt   DateTime @default(now())

  membres     TontineMembre[]
  versements  Versement[]
}

model TontineMembre {
  id          String   @id @default(cuid())
  tontineId   String
  tontine     Tontine  @relation(fields: [tontineId], references: [id])
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  tourOrdre   Int
  createdAt   DateTime @default(now())
}

model Versement {
  id          String   @id @default(cuid())
  tontineId   String
  tontine     Tontine  @relation(fields: [tontineId], references: [id])
  montant     Float
  statut      String   @default("EN_ATTENTE")
  stripePaymentId String?
  createdAt   DateTime @default(now())
}

// ===== AVIS FOURNISSEURS =====
model Avis {
  id            String      @id @default(cuid())
  fournisseurId String
  fournisseur   Fournisseur @relation(fields: [fournisseurId], references: [id])
  note          Int         // 1-5
  commentaire   String?
  createdAt     DateTime    @default(now())
}

// ===== NOTIFICATIONS =====
model Notification {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  type        String   // "COMMANDE", "ALERTE_DOUANE", "STOCK", "TONTINE"
  titre       String
  message     String
  lu          Boolean  @default(false)
  createdAt   DateTime @default(now())
}
