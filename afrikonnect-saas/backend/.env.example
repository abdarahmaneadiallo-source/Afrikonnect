# ===== AFRIKONNECT — VARIABLES D'ENVIRONNEMENT =====
# Copier ce fichier en .env et remplir les valeurs

# ===== BASE DE DONNÉES (OVH Managed PostgreSQL) =====
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/afrikonnect_db?sslmode=require"

# ===== JWT =====
JWT_SECRET="votre_secret_jwt_tres_long_et_aleatoire_minimum_32_caracteres"

# ===== STRIPE =====
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_PRO="price_..."         # ID du prix Stripe pour le plan Pro (29€/mois)
STRIPE_PRICE_FOURNISSEUR="price_..." # ID du prix Stripe pour le plan Fournisseur (49€/mois)

# ===== ANTHROPIC IA (conformité douanière) =====
ANTHROPIC_API_KEY="sk-ant-..."

# ===== EMAIL (Brevo) =====
BREVO_API_KEY="xkeysib-..."
FROM_EMAIL="no-reply@afrikonnect.fr"
FROM_NAME="Afrikonnect"

# ===== SMS / WHATSAPP (Twilio) =====
TWILIO_ACCOUNT_SID="AC..."
TWILIO_AUTH_TOKEN="..."
TWILIO_PHONE="+33..."

# ===== OVH OBJECT STORAGE (fichiers/docs) =====
OVH_STORAGE_URL="https://storage.gra.cloud.ovh.net/v1/AUTH_..."
OVH_STORAGE_CONTAINER="afrikonnect-files"
OVH_STORAGE_TOKEN="..."

# ===== APP =====
NODE_ENV="production"
PORT=3001
FRONTEND_URL="https://afrikonnect.fr"

# ===== INSTRUCTIONS DÉPLOIEMENT OVH VPS =====
# 1. Connectez-vous à votre VPS OVH en SSH : ssh ubuntu@IP_VPS
# 2. Installez Node.js 20 : curl -fsSL https://deb.nodesource.com/setup_20.x | sudo -E bash -
# 3. sudo apt-get install -y nodejs
# 4. Installez PM2 : sudo npm install -g pm2
# 5. Clonez le projet : git clone votre-repo.git
# 6. cd afrikonnect-backend && npm install
# 7. Copiez ce fichier .env : cp .env.example .env && nano .env
# 8. Générez Prisma : npm run db:generate && npm run db:migrate
# 9. Démarrez avec PM2 : pm2 start src/index.js --name afrikonnect-api
# 10. Sauvegarde PM2 : pm2 save && pm2 startup
