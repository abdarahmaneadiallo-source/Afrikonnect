# ===== AFRIKONNECT FRONTEND — Variables d'environnement =====
# Copier en .env.local

# URL de votre API backend (OVH VPS)
NEXT_PUBLIC_API_URL=https://api.afrikonnect.fr/api

# Stripe clé publique
NEXT_PUBLIC_STRIPE_KEY=pk_live_...

# URL du site
NEXT_PUBLIC_APP_URL=https://app.afrikonnect.fr

# ===== DÉPLOIEMENT SUR OVH =====
# Option A — Hébergement mutualisé OVH (plus simple)
#   1. npm run build → génère le dossier .next/
#   2. Configurer OVH pour Node.js : Manager → Hébergements → Node.js
#   3. Uploader via FTP ou Git
#   4. npm start sur le serveur

# Option B — VPS OVH (recommandé)
#   1. ssh ubuntu@IP_VPS
#   2. sudo apt install nodejs npm nginx
#   3. npm install && npm run build
#   4. pm2 start npm --name "afrikonnect-front" -- start
#   5. Configurer Nginx reverse proxy vers port 3000
